# ============================================================================
# .gitignore  (comments MUST be on their own line — trailing #comments become
# part of the pattern and silently fail to match)
# ============================================================================

# ---- Regenerable pipeline outputs (recreated by run_all.R) ----
# central SCE + intermediates (large .rds; regenerated by 00)
data/
# metrics, validation_log, peeks, inferCNV working dir
results/
*.rds

# keep figs/ (small PNGs) and truth/ (small CSVs) tracked on purpose

# ---- Real / patient data (never commit) ----
*.mat.gz
*.h5
*.h5ad
*.loom
*.mtx
GSE*
raw_data/
real_data/

# ---- R session / tooling cruft ----
.Rhistory
.RData
.Rproj.user/
*.Rproj
*.log
# machine-specific (JAGS_HOME path); ensure_jags() auto-detects anyway
.Renviron
# sessionInfo.txt IS committed on purpose (records the exact environment)

# ---- renv: keep the lockfile, ignore the large machine-specific library ----
renv/library/
renv/local/
renv/cellar/
renv/staging/

# ---- OS / editor ----
.DS_Store
Thumbs.db
*~
.vscode/

# ---- scratch (temporary diagnostic scripts like _diag.R) ----
_*.R
